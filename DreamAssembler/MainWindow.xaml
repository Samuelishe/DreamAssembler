<Window x:Class="DreamAssembler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:DreamAssembler.App.ViewModels"
        mc:Ignorable="d"
        Title="DreamAssembler"
        Width="1100"
        Height="840"
        MinWidth="960"
        MinHeight="760"
        Icon="Assets/Icons/dreamassembler.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#12000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1E000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11"
                                    SnapsToDevicePixels="True" />
                            <Border x:Name="HoverOverlay"
                                    Background="Transparent"
                                    CornerRadius="11" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Background" Value="#12FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#55FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Background" Value="#22000000" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#0E000000" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="28" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Text="⌄" />
                                </Grid>
                            </Border>
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource PanelBackgroundBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="11">
                                    <ScrollViewer Margin="4"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#12000000" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResultActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="OverlayActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0EFFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style x:Key="ChromeTagBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="#0C000000" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="HoverActionHostStyle" TargetType="StackPanel">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="IsHitTestVisible" Value="True" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsLexicalMode, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                    <Setter Property="Opacity" Value="0.58" />
                    <Setter Property="Margin" Value="0,0,0,14" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Opacity" Value="0.82" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubtleThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#66756A5F"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubtleScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SubtleThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid TextElement.FontFamily="{StaticResource UiFontFamily}">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid Margin="10,6,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="DreamAssembler" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding ShellModeLabel}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource WindowButtonStyle}"
                            Click="SettingsButton_OnClick"
                            ToolTip="Оформление и настройки">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="&#xE713;" />
                    </Button>
                    <Button Style="{StaticResource WindowButtonStyle}"
                            Click="ReadingModeButton_OnClick"
                            ToolTip="Режим чтения">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="&#xE7F4;" />
                    </Button>
                    <Button Style="{StaticResource WindowButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            ToolTip="Свернуть">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="&#xE921;" />
                    </Button>
                    <Button Style="{StaticResource WindowButtonStyle}"
                            Click="MaximizeRestoreButton_OnClick"
                            ToolTip="Развернуть или восстановить">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="&#xE922;" />
                    </Button>
                    <Button Style="{StaticResource WindowButtonStyle}"
                            Click="CloseButton_OnClick"
                            ToolTip="Закрыть">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="&#xE8BB;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="18,0,18,10">
            <TextBlock FontFamily="{StaticResource DisplayFontFamily}"
                       FontSize="42"
                       FontWeight="Black"
                       Foreground="{DynamicResource TitleGradientBrush}"
                       Text="DreamAssembler" />
        </Grid>

        <Grid Grid.Row="2"
              Margin="18,0,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding ControlPanelWidth}" />
                <ColumnDefinition Width="{Binding ContentGapWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                        <Setter Property="Padding" Value="18" />
                        <Setter Property="Opacity" Value="0.98" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLexicalMode}" Value="True">
                                <Setter Property="Padding" Value="14,12,14,12" />
                                <Setter Property="Opacity" Value="0.9" />
                                <Setter Property="Background" Value="#0A000000" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding ControlPanelTitle}" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ControlPanelHint}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Margin="0,18,0,6"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Тип генерации" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding Modes}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              SelectedItem="{Binding SelectedMode}"
                              DisplayMemberPath="DisplayName" />

                    <TextBlock Margin="0,18,0,6"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Уровень абсурдности" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding AbsurdityLevels}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              IsEnabled="{Binding IsAbsurditySelectionEnabled}"
                              SelectedItem="{Binding SelectedAbsurdityLevel}"
                              DisplayMemberPath="DisplayName" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding AbsurdityModeNote}" />

                    <TextBlock Margin="0,18,0,6"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Количество результатов" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding ResultCountOptions}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              SelectedItem="{Binding ResultCount}" />

                    <Button Margin="0,24,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding GenerateCommand}"
                            Content="Сгенерировать" />

                    <Button Margin="0,10,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearHistoryCommand}"
                            Content="Очистить историю" />

                    <Border Margin="0,18,0,0"
                            Padding="12"
                            Background="#0E000000"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLexicalMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="Последнее действие" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{Binding IsActionError, Converter={StaticResource BooleanToBrushConverter}}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ActionStatusMessage}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="2,0,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding ResultsSectionTitle}" />
                        <Border Margin="0,8,0,0"
                                HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ChromeTagBorderStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLexicalMode}" Value="True" />
                                                <Condition Binding="{Binding HasSelectedLexicalAtmosphere}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                                           Text="{Binding LexicalAtmosphereEyebrow}" />
                                <TextBlock Margin="8,0,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedLexicalAtmosphereLabel}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Margin="0,5,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding SummaryText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ResultsSectionHint}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Margin" Value="0,8,0,0" />
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Top"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding LastGeneratedAtText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Border Grid.Row="1"
                        x:Name="LexicalSpotlightBorder"
                        Margin="0,18,0,8"
                        Padding="30,28,30,32"
                        Background="#0C000000"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="LexicalSpotlightTransform" />
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLexicalMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel MaxWidth="760"
                                HorizontalAlignment="Center">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding LexicalSpotlightTitle}" />
                        <Border Margin="0,12,0,0"
                                Padding="11,4"
                                HorizontalAlignment="Center"
                                Background="#12000000"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedLexicalAtmosphere}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding SelectedLexicalAtmosphereLabel}" />
                        </Border>
                        <TextBlock Margin="0,16,0,0"
                                   FontFamily="{DynamicResource ReadingFontFamily}"
                                   FontSize="44"
                                   FontWeight="SemiBold"
                                   LineHeight="54"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedResult.Text, TargetNullValue=Сначала соберите несколько фрагментов и выберите один для чтения.}" />
                        <StackPanel Margin="0,20,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding CopyResultCommand}"
                                    CommandParameter="{Binding SelectedResult}"
                                    Content="Копировать" />
                            <Button Margin="10,0,0,0"
                                    Click="ReadingModeButton_OnClick"
                                    Content="Открыть в режиме чтения">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLexicalMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Padding="10">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                            <Setter Property="Padding" Value="10" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLexicalMode}" Value="True">
                                    <Setter Property="Padding" Value="10,8,10,10" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding ResultsListCaption}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox x:Name="ResultsList"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 ItemsSource="{Binding Results}"
                                 SelectedItem="{Binding SelectedResult}"
                                 SelectionChanged="ResultsList_OnSelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="False"
                                 ItemContainerStyle="{StaticResource ResultItemContainerStyle}">
                            <ListBox.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource SubtleScrollBarStyle}" />
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ResultItemViewModel}">
                                    <Border Margin="4,2"
                                            Padding="16"
                                            MinWidth="{Binding DataContext.ResultCardMinWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            MaxWidth="{Binding DataContext.ResultCardMaxWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            HorizontalAlignment="Left"
                                            Background="#D8FFFFFF"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="Padding" Value="20,18,20,22" />
                                                <Setter Property="CornerRadius" Value="13" />
                                                <Setter Property="Background" Value="#ECE6DD" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsLexicalMode, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                        <Setter Property="Padding" Value="26,24,26,28" />
                                                        <Setter Property="CornerRadius" Value="14" />
                                                        <Setter Property="Background" Value="#EFEAE3" />
                                                        <Setter Property="BorderBrush" Value="#20FFFFFF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Скопировать"
                                                          Command="{Binding DataContext.CopyResultCommand, Source={x:Reference ResultsList}}"
                                                          CommandParameter="{Binding}" />
                                                <MenuItem Header="Удалить"
                                                          Command="{Binding DataContext.RemoveResultCommand, Source={x:Reference ResultsList}}"
                                                          CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Text="{Binding Header}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsLexicalMode, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <StaticResource ResourceKey="HoverActionHostStyle" />
                                                </StackPanel.Style>
                                                <Button Style="{StaticResource ResultActionButtonStyle}"
                                                        Command="{Binding DataContext.CopyResultCommand, Source={x:Reference ResultsList}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Копировать" />
                                                <Button Margin="8,0,0,0"
                                                        Style="{StaticResource ResultActionButtonStyle}"
                                                        Command="{Binding DataContext.RemoveResultCommand, Source={x:Reference ResultsList}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Удалить" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,12,0,0"
                                                       FontFamily="{DynamicResource ReadingFontFamily}"
                                                       FontSize="{Binding DataContext.ResultTextFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       FontWeight="SemiBold"
                                                       LineHeight="{Binding DataContext.ResultTextLineHeight, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       Text="{Binding Text}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextAlignment" Value="Center" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsLexicalMode, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                                                                <Setter Property="TextAlignment" Value="Center" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Popup x:Name="SettingsPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=SettingsButton}"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Margin="0,8,0,0"
                    Padding="14"
                    Width="336"
                    Background="#F6FBF9F5"
                    BorderBrush="#D7D0C5"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding SettingsPopupTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SettingsPopupHint}" />
                    <TextBlock Margin="0,14,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Тема" />
                    <ComboBox Margin="0,6,0,0"
                              Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding ThemeOptions}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              SelectedItem="{Binding SelectedTheme}"
                              DisplayMemberPath="DisplayName" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ThemeDescription}" />
                    <StackPanel Margin="0,10,0,0"
                                Orientation="Horizontal">
                        <Border Width="28"
                                Height="28"
                                CornerRadius="14"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="#D7D0C5"
                                BorderThickness="1" />
                        <Border Margin="8,0,0,0"
                                Width="28"
                                Height="28"
                                CornerRadius="14"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="#D7D0C5"
                                BorderThickness="1" />
                        <Border Margin="8,0,0,0"
                                Width="28"
                                Height="28"
                                CornerRadius="14"
                                Background="{DynamicResource AccentBrush}"
                                BorderBrush="#D7D0C5"
                                BorderThickness="1" />
                    </StackPanel>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Шрифт чтения" />
                    <ComboBox Margin="0,6,0,0"
                              Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding ReadingFontOptions}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              SelectedItem="{Binding SelectedReadingFont}"
                              DisplayMemberPath="DisplayName" />
                    <Border Margin="0,10,0,0"
                            Padding="12"
                            Background="#0A000000"
                            BorderBrush="#DDD5C9"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="Предпросмотр чтения" />
                            <TextBlock Margin="0,8,0,0"
                                       FontFamily="{DynamicResource ReadingFontFamily}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       LineHeight="32"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ReadingFontPreviewText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#0A000000"
                            BorderBrush="#DDD5C9"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="Текущий статус данных" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{Binding IsFallbackActive, Converter={StaticResource BooleanToBrushConverter}}"
                                       TextWrapping="Wrap"
                                       Text="{Binding DataStatusMessage}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="Статус настроек" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SettingsStatusMessage}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#0A000000"
                            BorderBrush="#DDD5C9"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="About" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="{Binding AppVersion}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="DreamAssembler — rule-based генератор предложений, коротких текстов и словесных ассоциаций без нейросетевой генерации." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>

        <Grid x:Name="ReadingModeOverlay"
              Grid.RowSpan="3"
              Panel.ZIndex="20"
              Background="#ED0E0D13"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="24,20,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="12"
                               Foreground="#D9FFFFFF"
                               Text="Режим чтения" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#8FFFFFFF"
                               Text="F11 или Esc" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource OverlayActionButtonStyle}"
                            Command="{Binding CopyResultCommand}"
                            CommandParameter="{Binding SelectedResult}"
                            Content="Копировать" />
                    <Button Margin="10,0,0,0"
                            Style="{StaticResource OverlayActionButtonStyle}"
                            Click="ExitReadingModeButton_OnClick"
                            Content="Закрыть" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="72,36,72,56">
                <Border MaxWidth="1080"
                        Padding="48,44"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0AFFFFFF"
                        BorderBrush="#18FFFFFF"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#A6FFFFFF"
                                   Text="{Binding ReadingModeTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#99FFFFFF"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedLexicalAtmosphereDescription}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedLexicalAtmosphere}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,22,0,0"
                                   FontFamily="{DynamicResource ReadingFontFamily}"
                                   FontSize="46"
                                   FontWeight="SemiBold"
                                   LineHeight="62"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedResult.Text, TargetNullValue=Сначала выберите результат для режима чтения.}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
