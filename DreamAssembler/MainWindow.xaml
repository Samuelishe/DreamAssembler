<Window x:Class="DreamAssembler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DreamAssembler.App.ViewModels"
        mc:Ignorable="d"
        Title="DreamAssembler"
        Width="1080"
        Height="820"
        MinWidth="920"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F4EF">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFD9D2C6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF40352B" />
            <Setter Property="BorderBrush" Value="#FF40352B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FF332D28" />
            <Setter Property="Background" Value="#FFF2ECE3" />
            <Setter Property="BorderBrush" Value="#FFE1D7C8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="InputComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="ResultActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ResultItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubtleThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#66796F63"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubtleScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SubtleThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Style="{StaticResource SectionBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#FF2C2B28"
                               Text="DreamAssembler" />
                    <TextBlock Margin="0,8,0,0"
                               MaxWidth="560"
                               FontSize="14"
                               Foreground="#FF5A5750"
                               TextWrapping="Wrap"
                               Text="Rule-based генератор русскоязычных предложений, коротких текстов, словосочетаний, коротких фраз и абсурдных идей." />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="18,0,0,0"
                        Padding="12"
                        Background="#FFF8F1E4"
                        BorderBrush="#FFE6D7C0"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#FF3E3A33"
                                   Text="Состояние" />
                        <TextBlock Margin="0,8,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="#FF3E3A33"
                                   Text="Данные" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{Binding IsFallbackActive, Converter={StaticResource BooleanToBrushConverter}}"
                                   TextWrapping="Wrap"
                                   Text="{Binding DataStatusMessage}" />
                        <TextBlock Margin="0,12,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="#FF3E3A33"
                                   Text="Настройки" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#FF5A5750"
                                   TextWrapping="Wrap"
                                   Text="{Binding SettingsStatusMessage}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18"
                    Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FF2C2B28"
                               Text="Параметры" />

                    <TextBlock Margin="0,18,0,6"
                               Foreground="#FF4B4740"
                               Text="Тип генерации" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding Modes}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              SelectedItem="{Binding SelectedMode}"
                              DisplayMemberPath="DisplayName" />

                    <TextBlock Margin="0,18,0,6"
                               Foreground="#FF4B4740"
                               Text="Уровень абсурдности" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding AbsurdityLevels}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              IsEnabled="{Binding IsAbsurditySelectionEnabled}"
                              SelectedItem="{Binding SelectedAbsurdityLevel}"
                              DisplayMemberPath="DisplayName" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF857E73"
                               TextWrapping="Wrap"
                               Text="{Binding AbsurdityModeNote}" />

                    <TextBlock Margin="0,18,0,6"
                               Foreground="#FF4B4740"
                               Text="Количество результатов" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding ResultCountOptions}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              SelectedItem="{Binding ResultCount}" />

                    <Button Margin="0,24,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding GenerateCommand}"
                            Content="Сгенерировать" />

                    <Button Margin="0,10,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearHistoryCommand}"
                            Content="Очистить историю" />

                    <Border Margin="0,18,0,0"
                            Padding="10"
                            Background="#FFF8F1E4"
                            BorderBrush="#FFE6D7C0"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF3E3A33"
                                       Text="Последнее действие" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{Binding IsActionError, Converter={StaticResource BooleanToBrushConverter}}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ActionStatusMessage}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="18"
                        Style="{StaticResource SectionBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2C2B28"
                                       Text="Результаты" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#FF5A5750"
                                       Text="{Binding SummaryText}" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Top"
                                   Foreground="#FF857E73"
                                   Text="{Binding LastGeneratedAtText}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Padding="10"
                        Style="{StaticResource SectionBorderStyle}">
                    <ListBox x:Name="ResultsList"
                             ItemsSource="{Binding Results}"
                             SelectedItem="{Binding SelectedResult}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="False"
                             ItemContainerStyle="{StaticResource ResultItemContainerStyle}">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource SubtleScrollBarStyle}" />
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ResultItemViewModel}">
                                <Border Margin="4,2"
                                        Padding="16"
                                        MinWidth="260"
                                        MaxWidth="{Binding DataContext.ResultCardMaxWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        HorizontalAlignment="Left"
                                        Background="#FFF9F7F3"
                                        BorderBrush="#FFE2DBD2"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Скопировать"
                                                      Command="{Binding DataContext.CopyResultCommand, Source={x:Reference ResultsList}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="Удалить"
                                                      Command="{Binding DataContext.RemoveResultCommand, Source={x:Reference ResultsList}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF6A6258"
                                                   Text="{Binding Header}" />
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal">
                                            <Button Style="{StaticResource ResultActionButtonStyle}"
                                                    Command="{Binding DataContext.CopyResultCommand, Source={x:Reference ResultsList}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Копировать" />
                                            <Button Margin="8,0,0,0"
                                                    Style="{StaticResource ResultActionButtonStyle}"
                                                    Command="{Binding DataContext.RemoveResultCommand, Source={x:Reference ResultsList}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Удалить" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,10,0,0"
                                                   FontFamily="Georgia"
                                                   FontSize="{Binding DataContext.ResultTextFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                   LineHeight="{Binding DataContext.ResultTextLineHeight, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                   HorizontalAlignment="Left"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="None"
                                                   Foreground="#FF272622"
                                                   Text="{Binding Text}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
